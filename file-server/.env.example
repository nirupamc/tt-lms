# File Server Configuration
FILE_SERVER_PORT=4000

# Supabase JWT Secret (copy from Supabase Dashboard > Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Base path for video assets (absolute path on server)
ASSETS_BASE_PATH=C:/tantech/assets

# Allowed origin for CORS (React app URL)
ALLOWED_ORIGIN=http://localhost:5173
